---
import { Image } from "astro:assets";
import type { InferEntrySchema } from "astro:content";

interface Props {
  postId: string;
  post: InferEntrySchema<"blog">;
  class?: string;
  isLarge?: boolean;
}

const {
  postId,
  post,
  isLarge = false,
  class: className,
  ...rest
} = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/covers/**/*.{jpeg,jpg,png,gif,webp}"
);

const imagePath = post.coverImage ? `/src/assets${post.coverImage}` : null;
const imageSrc = imagePath && images[imagePath] ? images[imagePath]() : null;

const formattedDate = post.pubDate
  ? new Date(post.pubDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<article class:list={["card", className, isLarge && "large"]} {...rest}>
  <a href={`/blog/${postId}`} class="card-wrapper">
    <div class="card-image">
      <div class="responsive">
        {post.coverImage && imageSrc && (
          <Image 
            src={imageSrc} 
            alt={post.title} 
            width={ isLarge ? 600 : 300} 
            height={ isLarge ? 400 : 169} 
            format="webp" 
            sizes="(max-width: 600px) 100vw, 300px" 
          />
        )}
      </div>
    </div>
    <div class="card-content">
      <header class="card-header">
        <div class="header-content">
          {post.category && <span class="category">{post.category}</span>}
          {post.isFeatured && <span class="featured">Featured</span>}
        </div>
        <h2 class="title">{post.title}</h2>
      </header>

      {post.description && <p class="description">{post.description}</p>}

      <footer class="card-footer">
        {formattedDate && <time datetime={post.pubDate?.toISOString()} class="date">{formattedDate}</time>}
      </footer>
    </div>
  </a>
</article>

<style>
  .card {
    border-radius: 1rem;
    background: var(--color-background-lighter);
    box-shadow: 0 1px 10px 0 rgba(0, 0, 0, 0.03);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    overflow: hidden;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 10px 25px -5px rgba(0, 0, 0, 0.1),
      0 8px 10px -6px rgba(0, 0, 0, 0.1);
  }

  .card-wrapper {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    padding: 1.5rem;
    gap: 1.5rem;
  }

  .large .card-wrapper {
    padding: 2rem;
    gap: 2rem;
  }

  .card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .large .card-content {
    gap: 1rem;
  }

  .header-content {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .featured {
    color: var(--color-background-darker);
    padding: 0 0.5rem;
    border-radius: 4px;
    background: var(--color-primary);
  }

  .date {
    font-size: 0.875rem;
    display: block;
    opacity: 0.5;
  }

  .title {
    font-size: 1.2rem;
    line-height: 1.3;
    font-weight: 700;
    margin: 0;
  }

  .large .title {
    font-size: 2rem;
    line-height: 1.1;
    @media only screen and (min-width: 818px) {
      font-size: 2.2rem;
    }
  }

  .description {
    line-height: 1.6;
    margin: 0;
  }

  .large .description {
    font-size: 1.1rem;
    line-height: 1.6;
    @media only screen and (min-width: 818px) {
      font-size: 1.2rem;
    }
  }

  .card-footer {
    display: flex;
    align-items: center;
    font-size: 0.875rem;
  }

  .category {
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  /* Image Responsive Ratio 16:9 */
  .responsive {
    width: 100%;
    height: 0;
    padding-bottom: 56.25%;
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
    background: var(--color-background-darker);
  }

  .responsive img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
