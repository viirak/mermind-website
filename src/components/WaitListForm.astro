---
import { actions } from "astro:actions";
import Button from "./elements/Button.astro";
import FormField from "./elements/FormField.astro";
---

<form method="POST" action={actions.submitWaitList}>
  <!-- Honeypot: hidden from humans, bots will fill it -->
  <div class="hp-field" aria-hidden="true">
    <label for="website">Website</label>
    <input
      type="text"
      id="website"
      name="website"
      tabindex="-1"
      autocomplete="off"
    >
  </div>
  <div class="waitlist-form">
    <div class="group">
      <FormField
        id="name"
        label="Name"
        name="name"
        placeholder="Your name"
        maxlength={30}
        required
      />
      <FormField
        id="email"
        label="Email"
        name="email"
        type="email"
        placeholder="Your email"
        maxlength={100}
        required
      />
    </div>
    <div class="group">
      <FormField
        id="company"
        label="Company"
        name="company"
        placeholder="Your company"
        maxlength={100}
      />
      <FormField
        id="storeUrl"
        label="Store URL"
        name="storeUrl"
        placeholder="Your store URL"
        maxlength={100}
        required
      />
    </div>
    <div class="group">
      <Button type="submit" label="Join the waitlist" variant="primary" size="lg" />
    </div>
    <div class="disclaimer">No spam. Just updates as we make progress.</div>
  </div>
</form>

<div id="waitlist-alert" class="alert"></div>

<script>
  import { actions, isInputError } from "astro:actions";
  const form = document.querySelector("form[action*='submitWaitList']") as HTMLFormElement;
  const submitBtn = form?.querySelector("button[type='submit']") as HTMLButtonElement;
  const alert = document.getElementById("waitlist-alert") as HTMLDivElement;
  if (form) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      submitBtn.disabled = true;
      submitBtn.classList.add("loading");
      const formData = new FormData(form);
      formData.delete("website"); // remove honeypot field
      const errorHTML = `<h3>Oops!</h3><p>Something went wrong. Please try again later.</p>`;
      try {
        const { error } = await actions.submitWaitList(formData);
        if (error) {
          if (isInputError(error)) {
            alert.classList.add("error");
            const listElement = document.createElement("ul");
            for (const key of Object.keys(error.fields) as Array<keyof typeof error.fields>) {
              const message = error.fields[key];
              const listItem = document.createElement("li");
              listItem.textContent = message ? message.join(", ") : null;
              listElement.appendChild(listItem);
            }
            alert.replaceChildren(listElement);
          } else {
            alert.classList.add("error");
            alert.innerHTML = errorHTML;
          }
        } else {
          form.remove();
          alert.classList.remove("error");
          alert.classList.add("success");
          alert.innerHTML = `<h3>You're on the list!</h3><p>We'll be in touch soon. Thanks for your interest!</p>`;
        }
      } catch (e) {
        alert.classList.add("error");
        alert.innerHTML = errorHTML;
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove("loading");
      }
    });
  }
</script>

<style>
  .waitlist-form {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    @media only screen and (min-width: 641px) {
      flex-direction: row;
      align-items: flex-end;
    }
  }

  .disclaimer {
    font-size: 0.875rem;
    color: var(--color-text-dimmed);
    margin-top: 0.5rem;
  }

  .alert {
    border-radius: 0.5rem;
    margin-top: 1rem;
    padding: 1rem 1.5rem;
    background: var(--color-background);
  }

  .alert:empty {
    display: none;
  }

  .alert.success {
    color: var(--color-text);
  }

  .alert.error {
    color: var(--color-danger);
  }

  :global(.alert h3),
  :global(.alert p) {
    margin: 0;
  }

  :global(.alert ul) {
    margin: 0;
    padding-left: 1rem;
  }
  
  .hp-field {
    display: none;
  }
</style>