---
interface Props {
	flat?: boolean;
	limed?: boolean;
	outlined?: boolean;
	centered?: boolean;
	striped?: boolean;
	class?: string;
	padding?: "sm" | "md" | "lg" | "xl" | "2xl";
}

const {
	flat = false,
	limed = false,
	outlined = false,
	centered = false,
	striped = false,
	class: className,
	padding = "md",
	...rest
} = Astro.props;
---

<div
  class:list={["card", `padding--${padding}`, flat && `flat`, limed && `limed`, centered && `centered`, striped && `striped`, outlined && `border--outlined`, className]}
  {...rest}
>
  <div class="card-body">
    <slot name="card-body-icon" />
    <div class="card-body--content">
      <slot />
    </div>
  </div>
</div>

<style>
  .card {
    padding: 2rem;
    border: 2px solid var(--color-background-lighter);
    border-radius: 1rem;
    background: var(--color-background-lighter);
    box-shadow: 2px 4px 16px rgba(0, 0, 0, 0.1);
  }

  .card.padding--sm {
    padding: 1rem;
  }

  .card.padding--md {
    padding: 1.5rem;
    @media only screen and (min-width: 641px) {
      padding: 2rem;
    }
  }

  .card.padding--lg {
    padding: 2.5rem;
    @media only screen and (min-width: 641px) {
      padding: 3rem;
    }
  }

  .card.padding--xl {
    padding: 3rem;
    @media only screen and (min-width: 641px) {
      padding: 4rem;
    }
  }

  .card.padding--2xl {
    padding: 4rem;
    @media only screen and (min-width: 641px) {
      padding: 5rem;
    }
  }

  .card .card-body {
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
    @media only screen and (min-width: 641px) {
      flex-direction: row;
      gap: 2rem;
      text-align: left;
      justify-content: flex-start;
    }
  }

  .card.centered .card-body {
    align-items: center;
    text-align: center;
  }

  .card.flat {
    box-shadow: none;
  }

  .card.limed {
    background: var(--color-background-limed);
  }

  .card.border--outlined {
    border-color: var(--color-primary);
  }

  .card.striped {
    background-image: repeating-linear-gradient(45deg, transparent, transparent 32px, var(--color-background) 32px, var(--color-background) 64px);
  }

  .card-body--content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card.centered .card-body--content {
    align-items: center;
  }

  :global(.card .card--actions) {
    display: flex;
    gap: 1rem;
    flex-direction: column;
    align-items: center;
    margin-top: 1rem;
    @media only screen and (min-width: 641px) {
      flex-direction: row;
    }
  }

  :global(.card.centered .card--actions) {
    justify-content: center;
  }

  :global(.card--header.narrow) {
    max-width: 45rem;
  }

  :global(.card.centered .card--header.narrow) {
    margin: 0 auto;
  }

  :global(.icon--highlight) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border-radius: 0.5rem;
    padding: 0.5rem;
  }
</style>
