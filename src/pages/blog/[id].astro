---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import Layout from "../../Layout.astro";
import Container from "../../components/Container.astro";
import Header from "../../components/Header.astro";
import TOC from "../../components/TOC.astro";
import Breadcrumb from "../../components/elements/Breadcrumb.astro";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});

const headerColor1 = "rgba(100, 100, 50, 0.1)";
const headerColor2 = "rgba(50, 150, 50, 0.0)";
const headerColor3 = "rgba(150, 200, 150, 0.1)";
const linearColor1 = "rgba(50, 150, 50, 0.1)";
const background = "linear-gradient(135deg, #aaddcc33, #aaddcc33);";

const coverImageSrc = `/src/assets${post.data.coverImage}`;

const maxWidth = "62rem";
---

<Layout
  title={post.data.title}
  description={post.data.description}
  canonicalUrl={`https://mermind.ai/blog/${post.id}`}
>
  <article>
    <Header
		color1={headerColor1}
		color2={headerColor2}
		color3={headerColor3}
		linearColor1={linearColor1}
		background={background}
	>
      <div class="header-wrapper">
        <div class="header-nav">
          <Breadcrumb>
            <li><a href="/blog" title="Blog">Blog</a></li>
            <li>
              <a
                href={`/blog/categories/${post.data.category}`}
                title="Category"
                >{post.data.category}</a
              >
            </li>
          </Breadcrumb>
          <a href="#" title="Back" onclick="window.history.back()">Back</a>
        </div>
        <div class="header-content">
          <div class="alt-title-wrapper">
            {post.data.altTitle && <span class="alt-title">{post.data.altTitle}</span>}
            {post.data.isFeatured && <span class="featured">Featured</span>}
          </div>
          <h1 class="title">{post.data.title}</h1>
          <div class="meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {formattedDate}
            </time>
            <span>•</span>
            {post.data.category && (
                <span>In <a href={`/blog/categories/${post.data.category}`}>{post.data.category}</a></span>
              )}
          </div>
        </div>
      </div>
    </Header>
    <Container>
      <div class="main--layout">
        <main>
          <div class="prose markdown-content">
            {post.data.coverImage && (
              <div class="cover-image">
                <Image
                  src={coverImageSrc}
                  alt={post.data.title}
                  width={600}
                  height={400}
                  format="webp"
                />
              </div>
            )}
            <h2 id="intro" class="intro hidden">Intro</h2>
            <Content />
          </div>
        </main>
        <aside>
          <TOC headings={[{ depth: 2, slug: "intro", text: "Intro" }, ...headings]} />
        </aside>
      </div>
    </Container>
  </article>
</Layout>

<style is:global define:vars={{ maxWidth }}>
  .markdown-content h2#intro {
    visibility: hidden;
    height: 0;
    margin: 0;
  }

  .header-wrapper {
    max-width: var(--maxWidth);
    margin: 0 auto;
  }

  .header-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-nav--right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    @media only screen and (min-width: 818px) {
      gap: 1rem;
    }
  }

  .header-nav--right .divider {
    display: inline-block;
    opacity: 0.2;
  }

  .header-content {
    margin-top: 2rem;
    @media only screen and (min-width: 1041px) {
      margin-top: 3rem;
    }
  }

  .meta {
    font-size: 0.875rem;
    color: var(--color-text-dimmed);
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .alt-title-wrapper {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .alt-title-wrapper .featured {
    color: var(--color-background);
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0 0.5rem;
    border-radius: 4px;
    background: var(--color-primary);
  }

  .main--layout {
    max-width: var(--maxWidth);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    @media only screen and (min-width: 1041px) {
      grid-template-columns: 3fr 1fr;
      gap: 2rem;
    }
  }

  .main--layout aside {
    position: relative;
    padding-top: 2rem;
    width: 20rem;
    display: none;
    @media only screen and (min-width: 1041px) {
      display: block;
    }
  }

  /* Prose Styling */
  .prose {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-body);
    padding-top: 2rem;
    @media only screen and (min-width: 818px) {
      font-size: 1.125rem;
    }
  }

  .title {
    font-size: 2.2rem;
    line-height: 1.3;
    font-weight: bold;
    margin-top: 1rem;

    @media only screen and (min-width: 818px) {
      font-size: 2.5rem;
    }

    @media only screen and (min-width: 1041px) {
      font-size: 3rem;
    }
  }

  .alt-title {
    text-transform: uppercase;
    font-weight: 600;
    @media only screen and (min-width: 818px) {
      font-size: 1.1rem;
    }
  }

  .prose p {
    margin-bottom: 1.5rem;
  }

  .prose h2 {
    font-size: 1.6rem;
    line-height: 1.4;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-heading);
    letter-spacing: -0.02em;
    @media only screen and (min-width: 818px) {
      font-size: 1.8rem;
    }
  }

  .prose h3 {
    font-size: 1.5rem;
    line-height: 1.4;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-heading);
    @media only screen and (min-width: 818px) {
      font-size: 1.4rem;
    }
  }

  .prose ul,
  .prose ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose a {
    color: var(--color-primary-darker);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .prose a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .prose blockquote {
    border-left: 4px solid var(--color-border);
    padding-left: 1rem;
    margin-left: 0;
    font-style: italic;
  }

  .prose code {
    background: var(--color-background-offset);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: monospace;
  }

  .prose pre {
    background: #1e1e1e;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose pre code {
    background: transparent;
    padding: 0;
    color: #f0f0f0;
  }

  .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
  }
</style>
