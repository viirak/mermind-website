---
export const prerender = false;
import Layout from "../Layout.astro";
import Header from "../components/Header.astro";
import HeaderHero from "../components/HeaderHero.astro";
import Button from "../components/elements/Button.astro";
import Card from "../components/elements/Card.astro";
import FormField from "../components/elements/FormField.astro";
import Heading from "../components/elements/Heading.astro";
import Paragraph from "../components/elements/Paragraph.astro";
import Section from "../components/elements/Section.astro";
import SendIcon from "../icons/SendIcon.astro";

const {
	headerColor1 = "rgba(50, 50, 100, 0.1)",
	headerColor2 = "rgba(50, 40, 100, 0.0)",
	headerColor3 = "rgba(50, 40, 100, 0.1)",
	linearColor1 = "rgba(50, 40, 100, 0.1)",
	background = "linear-gradient(135deg, #00f7ff22, #00cfff22);",
} = Astro.props || {};
---

<Layout
  title="Contact Mermind"
  description="Get in touch with Mermind."
  canonicalUrl="https://mermind.ai/contact"
>
  <Header color1={headerColor1} color2={headerColor2} color3={headerColor3} linearColor1={linearColor1} background={background}>
    <HeaderHero
      paddingY="lg"
      altTitle="Contact Us"
      title="Start a conversation."
      lead="If you have a question, feedback about a product, or a recurring situation that might deserve a structured solution, you can reach us here."
      variant="default"
      size="default"
    >
      <div slot="graphic">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="100%"
          height="100%"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="0.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-messages-square-icon lucide-messages-square"
        >
          <path
            d="M16 10a2 2 0 0 1-2 2H6.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 2 14.286V4a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
          />
          <path
            d="M20 9a2 2 0 0 1 2 2v10.286a.71.71 0 0 1-1.212.502l-2.202-2.202A2 2 0 0 0 17.172 19H10a2 2 0 0 1-2-2v-1"
          />
        </svg>
      </div>
    </HeaderHero>
  </Header>
	<main>
    <Section>
      <div slot="header" class="section--header">
        <Heading level={2} size="xl">Send Us a Message</Heading>
        <Paragraph size="lg" dimmed>
          If you have a question, feedback about a product, or a recurring situation that might deserve a structured solution, you can reach us here.
        </Paragraph>
      </div>
	<Card padding="lg" outlined>
  <div class="form-context">
    <Heading level={2}>Message</Heading>
    <p>Please include as much detail as possible so we can understand your situation better.</p>
  </div>

  <form id="contact-form">
    <!-- Honeypot: hidden from humans, bots will fill it -->
    <div class="hp-field" aria-hidden="true">
      <label for="website">Website</label>
      <input
        type="text"
        id="website"
        name="website"
        tabindex="-1"
        autocomplete="off"
      >
    </div>
    <div class="group">
      <FormField
        id="name"
        label="Your Name"
        name="name"
        placeholder="Your name"
        maxlength={30}
        required
        transition:persist
      />
      <FormField
        id="email"
        label="Your Email"
        name="email"
        type="email"
        placeholder="Your email"
        maxlength={100}
        required
        transition:persist
      />
    </div>
    <div class="group">
      <FormField
        label="Company (optional)"
        name="company"
        placeholder="Your company (if applicable)"
        maxlength={100}
        transition:persist
      />
      <FormField
        label="What is this about?"
        name="subject"
        type="select"
        options={[
                  { value: "Product support", label: "Product support" },
                  { value: "Problem to share", label: "Problem to share" },
                  { value: "General inquiry", label: "General inquiry" },
                  { value: "Collaboration", label: "Collaboration" },
                  { value: "Other", label: "Other" }
                ]}
        required
        transition:persist
      />
    </div>
    <FormField
      label="Message"
      name="message"
      type="textarea"
      placeholder="How can we help?"
      maxlength={500}
      rows={5}
      required
      transition:persist
    />
    <div class="form--item actions">
      <Button type="submit" variant="primary" label="Submit" id="submit-btn">
        <slot slot="contentLeft">
          <SendIcon />
        </slot>
      </Button>
    </div>
  </form>
  <div id="alert" class="alert"></div>
</Card>
</Section>
</main>
</Layout>

<script>
  import { actions, isInputError } from "astro:actions";
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const alert = document.getElementById("alert") as HTMLDivElement;
  if (form) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      submitBtn.disabled = true;
      submitBtn.classList.add("loading");
      const formData = new FormData(form);
      formData.delete("website"); // remove honeypot field
      try {
        const { error } = await actions.submitContact(formData);
        if (isInputError(error)) {
          // remove all error class
          for (const ele of form.querySelectorAll(".error")) {
            ele.classList.remove("error");
          }
          alert.classList.add("error");
          const listElement = document.createElement("ul");
          for (const key of Object.keys(error.fields) as Array<
            keyof typeof error.fields
          >) {
            const message = error.fields[key];
            // input element
            const ele = document.getElementById(key.toString());
            if (ele) ele.classList.add("error");
            // create list item
            const listItem = document.createElement("li");
            listItem.textContent = message ? message.join(", ") : null;
            listElement.appendChild(listItem);
          }
          alert.replaceChildren(listElement);
        } else {
          form.remove();
          alert.classList.remove("error");
          alert.classList.add("success");
          alert.innerHTML = `<h3>Thank you for your message!</h3><p>We'll be in touch soon.</p>`;
        }
      } catch (e) {
        alert.classList.add("error");
        alert.innerHTML =
          "<h3>Oops! Something went wrong.</h3><p>Please try again later.</p>";
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove("loading");
      }
    });
  }
</script>

<style>
  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
    align-self: normal;
  }

  .form--item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: left;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    top: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .form--item.actions {
    align-items: flex-start;
  }

  .form--item.actions :global(button[disabled]) {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form--item.actions :global(button[data-loading]) {
    pointer-events: none;
  }

  .group {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    @media only screen and (min-width: 1249px) {
      flex-direction: row;
      gap: 1.5rem;
    }
  }

  .group .form--item {
    flex: 1;
  }

  .alert {
    border-radius: 0.5rem;
    margin-top: 1rem;
    padding: 1rem;
    align-self: normal;
    background: var(--color-surface);
  }

  .alert:empty {
    display: none;
  }

  .alert.success {
    color: var(--color-text);
  }

  .alert.error {
    color: var(--color-danger);
  }

  .input.error {
    border-color: var(--color-danger);
  }

  :global(.alert h3),
  :global(.alert p) {
    margin: 0;
  }
</style>
